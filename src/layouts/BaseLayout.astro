---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Anini - 前端工程师',
  description = '一个热爱创造的前端工程师的个人空间'
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F7F9F4" />
    <meta name="color-scheme" content="light" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts: Inter + DM Sans with display=swap for non-blocking load -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <!-- Inline critical CSS for faster first paint -->
    <style>
      body { background: #F7F9F4; }
    </style>
  </head>
  <body class="min-h-screen" style="background: #F7F9F4">
    <slot />
    <Analytics />
  </body>
</html>
